rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function own(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userRecord() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasAdminProfile() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? userRecord().data.get("role", "") == "admin"
        : false;
    }

    function isAdmin() {
      return signedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        || hasAdminProfile()
      );
    }

    function changedOnly(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    function shortText(value, maximum) {
      return value is string && value.size() <= maximum;
    }

    function validAudit(auditId, targetId) {
      return auditId is string
        && auditId.size() >= 12
        && existsAfter(/databases/$(database)/documents/auditLogs/$(auditId))
        && getAfter(/databases/$(database)/documents/auditLogs/$(auditId)).data.adminId == request.auth.uid
        && getAfter(/databases/$(database)/documents/auditLogs/$(auditId)).data.targetId == targetId
        && shortText(getAfter(/databases/$(database)/documents/auditLogs/$(auditId)).data.reason, 500);
    }

    function auditedAdminMutation(targetId) {
      let auditId = request.resource.data.get("lastAuditId", "");
      return isAdmin()
        ? auditId != resource.data.get("lastAuditId", "") && validAudit(auditId, targetId)
        : false;
    }

    function validBase(base) {
      return base is map
        && base.keys().hasOnly(["for", "vel", "hab", "res", "pod"])
        && base["for"] is int && base["for"] >= 2 && base["for"] <= 6
        && base.vel is int && base.vel >= 2 && base.vel <= 6
        && base.hab is int && base.hab >= 2 && base.hab <= 6
        && base.res is int && base.res >= 2 && base.res <= 6
        && base.pod is int && base.pod >= 2 && base.pod <= 6
        && base["for"] + base.vel + base.hab + base.res + base.pod == 20;
    }

    function safeInitialEconomy(data) {
      return data.gold == 100
        && data.millenniumCoins == 250
        && data.gachaEnergy == 30
        && data.affinityAttempts >= 0 && data.affinityAttempts <= 10
        && data.pityCounter == 0
        && data.totalRolls == 0
        && data.totalRares == 0
        && data.prestige == 0
        && data.xp == 0
        && data.level == 1
        && data.freePoints == 0
        && data.seasonPassXp == 0
        && data.premiumPassUnlocked == false
        && data.affinityId == ""
        && data.gachaVault is list && data.gachaVault.size() == 0
        && data.inventory is list && data.inventory.size() == 0
        && data.pets is list && data.pets.size() == 0
        && data.titles is list && data.titles.size() == 0
        && data.tokens is list && data.tokens.size() == 0
        && data.powers is list && data.powers.size() == 0
        && data.techniques is list && data.techniques.size() == 0
        && data.rollHistory is list && data.rollHistory.size() == 0
        && data.activeActivities is list && data.activeActivities.size() == 0;
    }

    function ownerCharacterCreate(uid) {
      let data = request.resource.data;
      return own(uid)
        && data.ownerId == uid
        && data.keys().hasOnly([
          "id", "ownerId", "displayName", "profilePublic", "playerName", "characterName",
          "characterAge", "characterDescription", "pronouns", "originType", "apparentAge",
          "realAge", "cultureId", "culture", "kingdomId", "regionId", "professionId", "profession", "objective", "fear",
          "playerLimits", "currentLocation", "physicalState", "essenceState", "creationLocked",
          "creationStatus", "technicalCreationComplete", "narrativeCreationComplete",
          "bannerUrl", "raceId", "classId", "factionId", "factionReputation",
          "factionJoinedAt", "affinityId", "affinityAttempts", "pityCounter", "totalRolls",
          "totalRares", "prestige", "base", "development", "xp", "level", "freePoints",
          "gold", "millenniumCoins", "gachaEnergy", "gachaEnergyUpdatedAt", "gachaFragments",
          "gachaVault", "gachaHistory", "activeActivities", "minigameStats", "activeTitleId",
          "pendingGift", "activeMissions", "premiumPassUnlocked", "seasonPassXp",
          "passMissionClaims", "rollHistory", "titles", "tokens", "pets", "inventory",
          "power", "powers", "powerSlots", "techniques", "story", "personality", "avatarUrl",
          "avatarPosition", "bannerPosition", "avatarFocusX", "avatarFocusY", "avatarZoom",
          "bannerFocusX", "bannerFocusY", "bannerZoom", "migrationVersion", "migrationState",
          "legacyArraysPreserved", "createdAt", "updatedAt"
        ])
        && data.creationLocked == false
        && validBase(data.base)
        && data.development == {"for": 0, "vel": 0, "hab": 0, "res": 0, "pod": 0}
        && safeInitialEconomy(data);
    }

    function technicalCreationUpdate() {
      let data = request.resource.data;
      let changed = data.diff(resource.data).affectedKeys();
      return resource.data.creationLocked == false
        && data.creationLocked == true
        && validBase(data.base)
        && shortText(data.playerName, 80)
        && shortText(data.characterName, 80)
        && shortText(data.raceId, 80)
        && shortText(data.classId, 80)
        && changed.hasOnly([
          "playerName", "displayName", "characterName", "characterAge", "pronouns",
          "originType", "apparentAge", "realAge", "raceId", "classId", "kingdomId",
          "regionId", "cultureId", "culture", "professionId", "profession",
          "currentLocation", "characterDescription", "avatarUrl", "bannerUrl",
          "avatarPosition", "bannerPosition", "avatarFocusX", "avatarFocusY",
          "avatarZoom", "bannerFocusX", "bannerFocusY", "bannerZoom", "base",
          "creationLocked", "creationStatus", "technicalCreationComplete", "updatedAt"
        ]);
    }

    function ownerProfileUpdate() {
      return changedOnly([
        "playerName", "displayName", "characterName", "characterAge", "pronouns",
        "originType", "apparentAge", "realAge", "cultureId", "culture",
        "professionId", "profession", "kingdomId", "regionId", "currentLocation",
        "characterDescription", "objective", "fear", "playerLimits", "story",
        "personality", "profilePublic", "activeTitleId", "avatarUrl", "bannerUrl",
        "avatarPosition", "bannerPosition", "avatarFocusX", "avatarFocusY",
        "avatarZoom", "bannerFocusX", "bannerFocusY", "bannerZoom",
        "mediaFocus", "activeMissions", "narrativeCreationComplete", "updatedAt"
      ])
      && shortText(request.resource.data.get("playerName", ""), 80)
      && shortText(request.resource.data.get("characterName", ""), 80)
      && shortText(request.resource.data.get("characterDescription", ""), 1000)
      && request.resource.data.get("activeMissions", []) is list
      && request.resource.data.get("activeMissions", []).size() <= 10;
    }

    function developmentPointUpdate() {
      let oldDevelopment = resource.data.get("development", {"for": 0, "vel": 0, "hab": 0, "res": 0, "pod": 0});
      let nextDevelopment = request.resource.data.development;
      let oldTotal = oldDevelopment["for"] + oldDevelopment.vel + oldDevelopment.hab + oldDevelopment.res + oldDevelopment.pod;
      let nextTotal = nextDevelopment["for"] + nextDevelopment.vel + nextDevelopment.hab + nextDevelopment.res + nextDevelopment.pod;
      return changedOnly(["development", "freePoints", "updatedAt"])
        && nextDevelopment is map
        && nextDevelopment.keys().hasOnly(["for", "vel", "hab", "res", "pod"])
        && nextTotal == oldTotal + 1
        && request.resource.data.freePoints == resource.data.freePoints - 1
        && request.resource.data.freePoints >= 0
        && nextDevelopment["for"] >= oldDevelopment["for"]
        && nextDevelopment.vel >= oldDevelopment.vel
        && nextDevelopment.hab >= oldDevelopment.hab
        && nextDevelopment.res >= oldDevelopment.res
        && nextDevelopment.pod >= oldDevelopment.pod;
    }

    function validReportCreate() {
      let data = request.resource.data;
      return data.keys().hasOnly([
          "type", "status", "reporterId", "reporterName", "targetId", "title",
          "category", "description", "steps", "expected", "actual", "device",
          "browser", "attachmentUrl", "build", "route", "viewport", "userAgent",
          "messageId", "source", "friendlyId", "createdAt"
        ])
        && data.reporterId == request.auth.uid
        && data.status in ["recebido", "aberto"]
        && shortText(data.type, 40)
        && shortText(data.get("title", ""), 160)
        && shortText(data.description, 5000)
        && shortText(data.get("targetId", ""), 128)
        && data.createdAt == request.time;
    }

    function validDirectMessage(data) {
      return data.keys().hasOnly([
          "senderId", "senderName", "targetId", "targetName", "participants",
          "text", "type", "clientId", "conversationId", "createdAt"
        ])
        && data.senderId == request.auth.uid
        && data.targetId is string
        && data.targetId != request.auth.uid
        && data.participants is list
        && data.participants.size() == 2
        && request.auth.uid in data.participants
        && data.targetId in data.participants
        && shortText(data.text, 2000)
        && data.text.size() > 0
        && data.createdAt == request.time;
    }

    function validConversationCreate() {
      let data = request.resource.data;
      return data.keys().hasOnly([
          "participantIds", "participantNames", "lastMessage", "lastMessageAt",
          "lastSenderId", "lastClientId", "createdAt", "updatedAt"
        ])
        && data.participantIds is list
        && data.participantIds.size() == 2
        && data.participantIds[0] != data.participantIds[1]
        && request.auth.uid in data.participantIds
        && data.lastSenderId == request.auth.uid
        && shortText(data.lastMessage, 240)
        && data.lastMessage.size() > 0
        && shortText(data.lastClientId, 160)
        && data.createdAt == request.time
        && data.lastMessageAt == request.time
        && data.updatedAt == request.time;
    }

    function validConversationUpdate() {
      let data = request.resource.data;
      return request.auth.uid in resource.data.participantIds
        && data.participantIds == resource.data.participantIds
        && data.lastSenderId == request.auth.uid
        && shortText(data.lastMessage, 240)
        && data.lastMessage.size() > 0
        && shortText(data.lastClientId, 160)
        && data.lastMessageAt == request.time
        && data.updatedAt == request.time
        && changedOnly([
          "participantNames", "lastMessage", "lastMessageAt", "lastSenderId",
          "lastClientId", "updatedAt"
        ]);
    }

    function validProgressRequestCreate() {
      let data = request.resource.data;
      return data.uid == request.auth.uid
        && data.status == "pendente"
        && data.type in ["mission", "training", "power", "technique", "guildMission", "market"]
        && data.keys().hasOnly([
          "uid", "playerName", "characterName", "type", "status", "missionId",
          "marketId", "guildId", "guildName", "partyIds", "title", "description", "rarity", "reward",
          "xp", "concept", "function", "manifestation", "range", "duration",
          "cost", "limitations", "countermeasures", "risks", "affinityId",
          "example", "basePowerId", "revision", "previousRequestId", "createdAt"
        ])
        && shortText(data.get("playerName", ""), 120)
        && shortText(data.get("characterName", ""), 120)
        && shortText(data.get("title", ""), 160)
        && shortText(data.get("description", ""), 5000)
        && shortText(data.get("marketId", ""), 160)
        && shortText(data.get("guildId", ""), 160)
        && shortText(data.get("guildName", ""), 160)
        && data.get("partyIds", []) is list
        && data.get("partyIds", []).size() <= 4
        && data.xp is int
        && data.xp >= 0
        && data.xp <= 1000
        && (!(data.type in ["power", "technique", "market"]) || data.xp == 0)
        && (data.type != "training" || data.xp <= 30)
        && data.createdAt == request.time;
    }

    function validCreationPlayerResponse() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return resource.data.uid == request.auth.uid
        && resource.data.type in ["power", "technique"]
        && resource.data.status in ["aguardando confirmação", "aguardando confirmacao"]
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.type == resource.data.type
        && request.resource.data.status in ["aceito pelo player", "contestado pelo player"]
        && shortText(request.resource.data.get("playerResponse", ""), 2000)
        && request.resource.data.get("playerRespondedAt", null) == request.time
        && request.resource.data.updatedAt == request.time
        && changed.hasOnly([
          "status", "playerResponse", "playerRespondedAt", "updatedAt"
        ]);
    }


    // Hotfix 3.1.1: compatibility for client-side beta operations.
    // These rules restore bounded writes while a trusted backend is not available.
    function ownerAffinityRollUpdate() {
      let oldAttempts = resource.data.get("affinityAttempts", 0);
      let nextAttempts = request.resource.data.get("affinityAttempts", 0);
      let spent = oldAttempts - nextAttempts;
      let oldRolls = resource.data.get("totalRolls", 0);
      let nextRolls = request.resource.data.get("totalRolls", 0);
      let oldRares = resource.data.get("totalRares", 0);
      let nextRares = request.resource.data.get("totalRares", 0);
      return changedOnly([
          "affinityAttempts", "pityCounter", "totalRolls", "totalRares",
          "prestige", "rollHistory", "affinityId", "affinitySnapshot", "updatedAt"
        ])
        && oldAttempts is int && nextAttempts is int
        && spent >= 1 && spent <= 10
        && nextAttempts >= 0
        && oldRolls is int && nextRolls == oldRolls + spent
        && oldRares is int && nextRares is int
        && nextRares >= oldRares && nextRares <= oldRares + spent
        && request.resource.data.get("pityCounter", 0) is int
        && request.resource.data.get("pityCounter", 0) >= 0
        && request.resource.data.get("pityCounter", 0) <= 30
        && request.resource.data.get("prestige", 0) is int
        && request.resource.data.get("prestige", 0) >= 0
        && request.resource.data.get("rollHistory", []) is list
        && request.resource.data.get("rollHistory", []).size() <= 60
        && shortText(request.resource.data.get("affinityId", ""), 80)
        && request.resource.data.get("affinitySnapshot", {}) is map;
    }

    function ownerAffinityChoiceUpdate() {
      return changedOnly(["affinityId", "affinitySnapshot", "updatedAt"])
        && resource.data.get("totalRolls", 0) > 0
        && shortText(request.resource.data.get("affinityId", ""), 80)
        && request.resource.data.get("affinitySnapshot", {}) is map;
    }

    function ownerGiftClaimUpdate() {
      let oldKeys = resource.data.get("giftClaimKeys", []);
      let nextKeys = request.resource.data.get("giftClaimKeys", []);
      return changedOnly(["pendingGift", "giftClaimKeys", "giftHistory", "updatedAt"])
        && resource.data.get("pendingGift", null) is map
        && request.resource.data.get("pendingGift", null) == null
        && oldKeys is list && nextKeys is list
        && nextKeys.size() == oldKeys.size() + 1 && nextKeys.size() <= 80
        && request.resource.data.get("giftHistory", []) is list
        && request.resource.data.get("giftHistory", []).size() <= 40;
    }

    function ownerPetHuntStartUpdate() {
      let oldEnergy = resource.data.get("gachaEnergy", 30);
      let nextEnergy = request.resource.data.get("gachaEnergy", 30);
      let oldActivities = resource.data.get("activeActivities", []);
      let nextActivities = request.resource.data.get("activeActivities", []);
      return changedOnly(["gachaEnergy", "gachaEnergyUpdatedAt", "gachaVault", "activeActivities", "updatedAt"])
        && oldEnergy is int && nextEnergy is int
        && nextEnergy >= 0 && nextEnergy < oldEnergy && oldEnergy - nextEnergy <= 5
        && resource.data.get("gachaVault", []) is list
        && request.resource.data.get("gachaVault", []) is list
        && request.resource.data.get("gachaVault", []).size() == resource.data.get("gachaVault", []).size()
        && oldActivities is list && nextActivities is list
        && nextActivities.size() == oldActivities.size() + 1 && nextActivities.size() <= 10;
    }

    function ownerPetHuntCompleteUpdate() {
      let oldActivities = resource.data.get("activeActivities", []);
      let nextActivities = request.resource.data.get("activeActivities", []);
      let oldKeys = resource.data.get("huntCompletionKeys", []);
      let nextKeys = request.resource.data.get("huntCompletionKeys", []);
      let oldCoins = resource.data.get("millenniumCoins", 0);
      let nextCoins = request.resource.data.get("millenniumCoins", 0);
      return changedOnly([
          "gachaVault", "activeActivities", "huntCompletionKeys", "millenniumCoins",
          "gachaFragments", "inventory", "huntHistory", "updatedAt"
        ])
        && oldActivities is list && nextActivities is list
        && nextActivities.size() == oldActivities.size() - 1 && nextActivities.size() >= 0
        && oldKeys is list && nextKeys is list
        && nextKeys.size() == oldKeys.size() + 1 && nextKeys.size() <= 80
        && oldCoins is int && nextCoins is int && nextCoins >= oldCoins && nextCoins <= oldCoins + 5000
        && request.resource.data.get("gachaVault", []) is list
        && request.resource.data.get("gachaVault", []).size() == resource.data.get("gachaVault", []).size()
        && request.resource.data.get("gachaFragments", {}) is map
        && request.resource.data.get("inventory", []) is list
        && request.resource.data.get("inventory", []).size() <= 250
        && request.resource.data.get("huntHistory", []) is list
        && request.resource.data.get("huntHistory", []).size() <= 60;
    }

    function ownerGachaInvokeUpdate() {
      let oldCoins = resource.data.get("millenniumCoins", 0);
      let nextCoins = request.resource.data.get("millenniumCoins", 0);
      let oldVault = resource.data.get("gachaVault", []);
      let nextVault = request.resource.data.get("gachaVault", []);
      let oldInventory = resource.data.get("inventory", []);
      let nextInventory = request.resource.data.get("inventory", []);
      let oldHistory = resource.data.get("gachaHistory", []);
      let nextHistory = request.resource.data.get("gachaHistory", []);
      let added = (nextVault.size() - oldVault.size()) + (nextInventory.size() - oldInventory.size());
      let spent = oldCoins - nextCoins;
      return changedOnly([
          "millenniumCoins", "gachaVault", "inventory", "gachaHistory", "updatedAt"
        ])
        && oldCoins is int && nextCoins is int
        && spent >= 100 && spent <= 1200
        && nextCoins >= 0
        && oldVault is list && nextVault is list
        && oldInventory is list && nextInventory is list
        && oldHistory is list && nextHistory is list
        && nextVault.size() >= oldVault.size()
        && nextInventory.size() >= oldInventory.size()
        && added >= 1 && added <= 10
        && nextVault.size() <= 250
        && nextInventory.size() <= 250
        && nextHistory.size() >= oldHistory.size()
        && nextHistory.size() <= 120
        && nextHistory.size() <= oldHistory.size() + 10;
    }

    function ownerVaultManagementUpdate() {
      let oldVault = resource.data.get("gachaVault", []);
      let nextVault = request.resource.data.get("gachaVault", []);
      return changedOnly(["gachaVault", "gachaFragments", "updatedAt"])
        && oldVault is list && nextVault is list
        && request.resource.data.get("gachaFragments", {}) is map
        && nextVault.size() >= oldVault.size() - 1
        && nextVault.size() <= oldVault.size()
        && nextVault.size() <= 250;
    }

    function ownerGachaRerollUpdate() {
      let oldCoins = resource.data.get("millenniumCoins", 0);
      let nextCoins = request.resource.data.get("millenniumCoins", 0);
      return changedOnly(["millenniumCoins", "gachaVault", "updatedAt"])
        && oldCoins is int && nextCoins is int
        && oldCoins - nextCoins >= 10 && oldCoins - nextCoins <= 500
        && nextCoins >= 0
        && request.resource.data.get("gachaVault", []) is list
        && request.resource.data.get("gachaVault", []).size() == resource.data.get("gachaVault", []).size()
        && request.resource.data.get("gachaVault", []).size() <= 250;
    }

    function ownerMinigameResultUpdate() {
      let oldEnergy = resource.data.get("gachaEnergy", 30);
      let nextEnergy = request.resource.data.get("gachaEnergy", 30);
      let oldCoins = resource.data.get("millenniumCoins", 0);
      let nextCoins = request.resource.data.get("millenniumCoins", 0);
      let oldKeys = resource.data.get("minigameCompletionKeys", []);
      let nextKeys = request.resource.data.get("minigameCompletionKeys", []);
      return changedOnly([
          "gachaEnergy", "gachaEnergyUpdatedAt", "millenniumCoins", "gachaFragments",
          "minigameCompletionKeys", "minigameStats", "minigameHistory",
          "lastAimRun", "lastTowerRun", "lastSealRun", "updatedAt"
        ])
        && oldEnergy is int && nextEnergy is int
        && nextEnergy >= 0 && nextEnergy <= 30
        && oldCoins is int && nextCoins is int
        && nextCoins >= oldCoins && nextCoins <= oldCoins + 5000
        && request.resource.data.get("gachaFragments", {}) is map
        && oldKeys is list && nextKeys is list
        && nextKeys.size() <= 80
        && nextKeys != oldKeys
        && request.resource.data.get("minigameStats", {}) is map
        && request.resource.data.get("minigameHistory", []) is list
        && request.resource.data.get("minigameHistory", []).size() <= 30
        && request.resource.data.get("lastAimRun", {}) is map
        && request.resource.data.get("lastTowerRun", {}) is map
        && request.resource.data.get("lastSealRun", {}) is map;
    }

    match /admins/{uid} {
      allow read: if own(uid) || isAdmin();
      allow write: if isAdmin();
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow create: if own(uid)
        && !exists(/databases/$(database)/documents/deletedUsers/$(uid))
        && request.resource.data.role == "player"
        && request.resource.data.email == request.auth.token.email;
      allow update: if own(uid)
        && changedOnly([
          "displayName", "online", "lastSeen", "lastAnnouncedAt", "acceptedTermsVersion",
          "acceptedTermsAt", "tutorialSeenVersion", "panicOfflineAt", "updatedAt"
        ]);
      allow update: if auditedAdminMutation(uid);
      allow delete: if isAdmin() && request.auth.uid != uid;
    }

    match /deletedUsers/{uid} {
      allow read, write: if isAdmin();
    }

    match /characters/{uid} {
      allow read: if own(uid) || isAdmin();
      allow create: if ownerCharacterCreate(uid);
      allow create: if isAdmin()
        && request.resource.data.ownerId == uid
        && validAudit(request.resource.data.lastAuditId, uid);
      allow update: if own(uid)
        && (
          technicalCreationUpdate()
          || ownerProfileUpdate()
          || developmentPointUpdate()
          || ownerAffinityRollUpdate()
          || ownerAffinityChoiceUpdate()
          || ownerGiftClaimUpdate()
          || ownerPetHuntStartUpdate()
          || ownerPetHuntCompleteUpdate()
          || ownerGachaInvokeUpdate()
          || ownerVaultManagementUpdate()
          || ownerGachaRerollUpdate()
          || ownerMinigameResultUpdate()
        );
      allow update: if auditedAdminMutation(uid);
      allow delete: if isAdmin() && request.auth.uid != uid;

      match /lore/{docId} {
        allow read: if own(uid) || isAdmin();
        allow create, update: if own(uid)
          && request.resource.data.keys().hasOnly([
            "description", "personality", "virtues", "flaws", "habits", "beliefs",
            "history", "originWorld", "milestones", "importantPeople", "traumas",
            "secrets", "primaryGoal", "secondaryGoal", "fear", "desire",
            "internalConflict", "speech", "moralLimits", "initialRelations",
            "publicPhrase", "playerLimits", "warningThemes", "consentThemes",
            "forbiddenThemes", "progress", "updatedAt"
          ]);
        allow create, update: if isAdmin();
        allow delete: if own(uid) || isAdmin();
      }

      match /developmentLogs/{logId} {
        allow read: if own(uid) || isAdmin();
        allow create: if own(uid)
          && request.resource.data.keys().hasOnly(["ownerId", "attribute", "amount", "before", "after", "createdAt"])
          && request.resource.data.ownerId == uid
          && request.resource.data.attribute in ["for", "vel", "hab", "res", "pod"]
          && request.resource.data.amount == 1
          && request.resource.data.after == request.resource.data.before + 1
          && request.resource.data.createdAt == request.time;
        allow update: if false;
        allow delete: if isAdmin();
      }

      match /inventory/{instanceId} {
        allow read: if own(uid) || isAdmin();
        allow update: if own(uid)
          && changedOnly(["equipped", "slot", "marketListed", "updatedAt"]);
        allow create, delete: if isAdmin();
        allow update: if isAdmin();
      }

      match /pets/{instanceId} {
        allow read: if own(uid) || isAdmin();
        allow update: if own(uid)
          && changedOnly(["equipped", "featured", "updatedAt"]);
        allow create, delete, update: if isAdmin();
      }

      match /titles/{titleId} {
        allow read: if own(uid) || isAdmin();
        allow write: if isAdmin();
      }

      match /powers/{powerId} {
        allow read: if own(uid) || isAdmin();
        allow write: if isAdmin();
      }

      match /techniques/{techniqueId} {
        allow read: if own(uid) || isAdmin();
        allow write: if isAdmin();
      }

      match /activities/{activityId} {
        allow read: if own(uid) || isAdmin();
        allow create: if own(uid)
          && request.resource.data.ownerId == uid
          && request.resource.data.state in ["preparing", "running"];
        allow update: if own(uid)
          && resource.data.ownerId == uid
          && request.resource.data.state in ["running", "paused", "cancelled", "failed"]
          && changedOnly(["state", "progress", "pausedAt", "cancelledAt", "updatedAt"]);
        allow create, update, delete: if isAdmin();
      }

      match /{subcollection}/{docId} {
        allow read: if own(uid) || isAdmin();
        allow write: if isAdmin()
          && subcollection in [
            "missions", "achievements", "discoveries", "history", "rewards", "minigameRuns"
          ];
      }
    }

    match /publicProfiles/{uid} {
      allow read: if isAdmin() || own(uid) || (signedIn() && resource.data.privacy == "public");
      allow create, update: if own(uid)
        && request.resource.data.ownerId == uid
        && request.resource.data.keys().hasOnly([
          "ownerId", "name", "player", "avatar", "banner", "title", "race",
          "class", "affinity", "culture", "profession", "kingdom", "region",
          "guild", "location", "publicPhrase", "privacy", "updatedAt"
        ])
        && request.resource.data.privacy in ["public", "private"]
        && request.resource.data.updatedAt == request.time;
      allow write: if isAdmin();
    }

    match /auditLogs/{auditId} {
      allow read: if isAdmin();
      allow create: if isAdmin()
        && request.resource.data.adminId == request.auth.uid
        && request.resource.data.keys().hasAll([
          "adminId", "targetId", "field", "previousValue", "nextValue", "reason", "createdAt"
        ])
        && shortText(request.resource.data.reason, 500)
        && request.resource.data.createdAt == request.time;
      allow update, delete: if false;
    }

    match /operationRequests/{operationId} {
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.status == "pending"
        && request.resource.data.type in [
          "affinity-roll", "gacha", "pass-claim", "market-buy", "market-trade",
          "auction-bid", "craft", "guild-create", "minigame-reward", "pet-recovery"
        ]
        && request.resource.data.keys().hasOnly([
          "ownerId", "type", "status", "payload", "idempotencyKey", "createdAt"
        ])
        && shortText(request.resource.data.idempotencyKey, 160)
        && request.resource.data.createdAt == request.time;
      allow read: if isAdmin() || resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /operationReceipts/{receiptId} {
      allow read: if isAdmin() || resource.data.ownerId == request.auth.uid;
      allow write: if isAdmin();
    }

    match /reports/{reportId} {
      allow create: if signedIn() && validReportCreate();
      allow read: if isAdmin() || resource.data.reporterId == request.auth.uid;
      allow update: if auditedAdminMutation(reportId)
        && changedOnly(["status", "reviewedBy", "reviewedAt", "adminNote", "lastAuditId", "updatedAt"]);
      allow delete: if isAdmin();
    }

    match /globalMessages/{messageId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.type == "global"
        && shortText(request.resource.data.text, 2000)
        && request.resource.data.text.size() > 0
        && request.resource.data.createdAt == request.time;
      allow create, delete: if isAdmin();
      allow update: if false;
      allow delete: if signedIn() && resource.data.senderId == request.auth.uid;
    }

    match /directMessages/{messageId} {
      allow create: if signedIn() && validDirectMessage(request.resource.data);
      allow read: if isAdmin() || (signedIn() && request.auth.uid in resource.data.participants);
      allow update: if false;
      allow delete: if isAdmin() || (signedIn() && resource.data.senderId == request.auth.uid);
    }

    match /conversations/{conversationId} {
      allow create: if signedIn() && validConversationCreate();
      allow read: if isAdmin() || (signedIn() && request.auth.uid in resource.data.participantIds);
      allow update: if signedIn() && validConversationUpdate();
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow create: if signedIn()
          && existsAfter(/databases/$(database)/documents/conversations/$(conversationId))
          && request.auth.uid in getAfter(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds
          && request.resource.data.conversationId == conversationId
          && request.resource.data.participants == getAfter(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds
          && validDirectMessage(request.resource.data);
        allow read: if isAdmin() || (signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds);
        allow update: if false;
        allow delete: if isAdmin() || (signedIn() && resource.data.senderId == request.auth.uid);
      }
    }

    match /progressRequests/{requestId} {
      allow create: if signedIn() && validProgressRequestCreate();
      allow read: if isAdmin()
        || resource.data.uid == request.auth.uid
        || (resource.data.get("partyIds", []) is list && request.auth.uid in resource.data.get("partyIds", []));
      allow update: if signedIn() && validCreationPlayerResponse();
      allow update: if auditedAdminMutation(requestId);
      allow delete: if isAdmin();
    }

    match /socialRequests/{requestId} {
      allow create: if signedIn()
        && request.resource.data.fromId == request.auth.uid
        && request.resource.data.status == "pendente"
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants;
      allow read: if isAdmin() || request.auth.uid in resource.data.participants;
      allow update: if signedIn()
        && request.auth.uid == resource.data.toId
        && changedOnly(["status", "respondedAt", "updatedAt"])
        && request.resource.data.status in ["aceito", "recusado"];
      allow update, delete: if isAdmin();
    }

    match /guilds/{guildId} {
      allow read: if signedIn();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow update: if signedIn()
        && resource.data.leaderId == request.auth.uid
        && request.resource.data.memberIds is list
        && request.resource.data.memberIds.size() <= 10
        && changedOnly(["name", "imageUrl", "description", "mural", "memberIds", "activeMission", "updatedAt"]);
      allow delete: if isAdmin();
    }

    match /guildMessages/{messageId} {
      allow create: if signedIn()
        && request.resource.data.senderId == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds
        && shortText(request.resource.data.text, 2000)
        && request.resource.data.createdAt == request.time;
      allow read: if isAdmin() || (signedIn() && request.auth.uid in resource.data.memberIds);
      allow update: if false;
      allow delete: if isAdmin() || (signedIn() && resource.data.senderId == request.auth.uid);
    }

    match /campaignDiary/{entryId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.authorId == request.auth.uid
        && shortText(request.resource.data.title, 160)
        && shortText(request.resource.data.text, 8000)
        && request.resource.data.createdAt == request.time;
      allow update, delete: if isAdmin();
    }

    match /profileViews/{viewId} {
      allow read: if isAdmin() || resource.data.targetId == request.auth.uid;
      allow create, update: if signedIn()
        && request.resource.data.viewerId == request.auth.uid
        && request.resource.data.targetId != request.auth.uid;
      allow delete: if isAdmin();
    }

    match /playerListings/{listingId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /marketTrades/{tradeId} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid in resource.data.participants);
      allow write: if isAdmin();
    }

    match /auctionBids/{bidId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /rankings/{rankingId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /{collection}/{docId} {
      allow read: if signedIn() && collection in [
        "races", "classes", "affinityCategories", "affinities", "itemCategories", "items",
        "gachaPets", "gachaItems", "gachaShardShops", "towerMaps", "gachaBanners",
        "missionPool", "weeklyMissions", "guildMissions", "biomes", "kingdoms", "regions",
        "cultures", "professions", "npcs", "rulesChapters", "faqEntries", "tutorialSteps",
        "wantedBoard", "bestiary", "marketListings", "auctionListings", "craftingRecipes",
        "techniqueLibrary", "achievements", "seasonPass", "passMissions", "reputationFactions",
        "worldLore", "worldEvents", "campaignPosts"
      ];
      allow write: if isAdmin() && collection in [
        "races", "classes", "affinityCategories", "affinities", "itemCategories", "items",
        "gachaPets", "gachaItems", "gachaShardShops", "towerMaps", "gachaBanners",
        "missionPool", "weeklyMissions", "guildMissions", "biomes", "kingdoms", "regions",
        "cultures", "professions", "npcs", "rulesChapters", "faqEntries", "tutorialSteps",
        "wantedBoard", "bestiary", "marketListings", "auctionListings", "craftingRecipes",
        "techniqueLibrary", "achievements", "seasonPass", "passMissions", "reputationFactions",
        "worldLore", "worldEvents", "campaignPosts"
      ];
    }
  }
}
