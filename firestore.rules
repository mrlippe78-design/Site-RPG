rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function adminEmail() {
      return signedIn()
        && request.auth.token.email == "mrlippe78@gmail.com";
    }

    function isAdmin() {
      return signedIn()
        && (
          adminEmail()
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
        );
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function playerCharacterUpdateAllowed() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly([
        "ownerId",
        "displayName",
        "playerName",
        "characterName",
        "characterAge",
        "characterDescription",
        "creationLocked",
        "avatarUrl",
        "bannerUrl",
        "avatarPosition",
        "bannerPosition",
        "raceId",
        "classId",
        "profilePublic",
        "base",
        "story",
        "personality",
        "affinityId",
        "affinityAttempts",
        "pityCounter",
        "totalRolls",
        "totalRares",
        "prestige",
        "rollHistory",
        "affinitySnapshot",
        "activeTitleId",
        "titles",
        "inventory",
        "pendingGift",
        "activeMissions",
        "updatedAt"
      ])
      && (
        resource.data.creationLocked != true
        || !changed.hasAny(["raceId", "classId"])
      )
      && (
        resource.data.creationLocked != true
        || !changed.hasAny(["base"])
        || (
          request.resource.data.base["for"] >= resource.data.base["for"]
          && request.resource.data.base["vel"] >= resource.data.base["vel"]
          && request.resource.data.base["hab"] >= resource.data.base["hab"]
          && request.resource.data.base["res"] >= resource.data.base["res"]
          && request.resource.data.base["pod"] >= resource.data.base["pod"]
        )
      );
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isAdmin()
        || (
          isOwner(userId)
          && (
            request.resource.data.role == "player"
            || (adminEmail() && request.resource.data.role == "admin")
          )
        );
      allow update: if isAdmin()
        || (
          isOwner(userId)
          && request.resource.data.role == resource.data.role
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "displayName",
            "online",
            "lastSeen",
            "lastAnnouncedAt",
            "acceptedTermsVersion",
            "acceptedTermsAt",
            "panicOfflineAt",
            "updatedAt"
          ])
        );
      allow delete: if isAdmin();
    }

    match /characters/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isAdmin() || (isOwner(userId) && playerCharacterUpdateAllowed());
      allow delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /{collection}/{docId} {
      allow read: if signedIn()
        && collection in [
          "races",
          "classes",
          "affinityCategories",
          "affinities",
          "itemCategories",
          "items",
          "missionPool",
          "weeklyMissions",
          "guildMissions",
          "globalMessages",
          "campaignDiary",
          "biomes",
          "kingdoms",
          "regions",
          "npcs",
          "rulesChapters",
          "faqEntries",
          "tutorialSteps",
          "wantedBoard",
          "bestiary",
          "marketListings",
          "auctionListings",
          "craftingRecipes",
          "techniqueLibrary",
          "achievements",
          "seasonPass",
          "passMissions",
          "reputationFactions"
        ];
      allow write: if isAdmin()
        && collection in [
          "races",
          "classes",
          "affinityCategories",
          "affinities",
          "itemCategories",
          "items",
          "missionPool",
          "weeklyMissions",
          "guildMissions",
          "globalMessages",
          "campaignDiary",
          "biomes",
          "kingdoms",
          "regions",
          "npcs",
          "rulesChapters",
          "faqEntries",
          "tutorialSteps",
          "wantedBoard",
          "bestiary",
          "marketListings",
          "auctionListings",
          "craftingRecipes",
          "techniqueLibrary",
          "achievements",
          "seasonPass",
          "passMissions",
          "reputationFactions"
        ];
    }

    match /globalMessages/{messageId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if isAdmin();
      allow delete: if signedIn();
    }

    match /directMessages/{messageId} {
      allow create: if signedIn() && request.auth.uid in request.resource.data.participants;
      allow read: if signedIn() && request.auth.uid in resource.data.participants;
      allow update: if false;
      allow delete: if signedIn() && request.auth.uid in resource.data.participants;
    }

    match /profileViews/{viewId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.resource.data.viewerId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow create: if signedIn();
      allow read: if isAdmin() || resource.data.reporterId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /progressRequests/{requestId} {
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow read: if isAdmin()
        || resource.data.uid == request.auth.uid
        || (resource.data.partyIds is list && request.auth.uid in resource.data.partyIds);
      allow update, delete: if isAdmin();
    }

    match /socialRequests/{requestId} {
      allow create: if signedIn()
        && request.resource.data.fromId == request.auth.uid
        && request.auth.uid in request.resource.data.participants;
      allow read: if isAdmin() || request.auth.uid in resource.data.participants;
      allow update: if isAdmin()
        || (
          signedIn()
          && request.auth.uid == resource.data.toId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "respondedAt", "updatedAt"])
        );
      allow delete: if isAdmin();
    }

    match /guilds/{guildId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.leaderId == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.memberIds.size() <= 10;
      allow update: if isAdmin()
        || (
          signedIn()
          && resource.data.leaderId == request.auth.uid
          && request.resource.data.memberIds.size() <= 10
        )
        || (
          signedIn()
          && request.auth.uid in request.resource.data.memberIds
          && request.resource.data.memberIds.size() <= 10
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["memberIds", "updatedAt"])
        );
      allow delete: if isAdmin();
    }

    match /guildMessages/{messageId} {
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.senderId
        && (isAdmin() || request.auth.uid in request.resource.data.memberIds);
      allow read: if isAdmin() || (signedIn() && request.auth.uid in resource.data.memberIds);
      allow update: if isAdmin();
      allow delete: if isAdmin() || (signedIn() && request.auth.uid in resource.data.memberIds);
    }

    match /guildMissions/{missionId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /campaignDiary/{entryId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
